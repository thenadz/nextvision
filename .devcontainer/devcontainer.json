// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/rust
{
	"name": "Rust",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/rust:2-1-trixie",

	// Forward host X11 display (Windows: X server on host.docker.internal).
	"containerEnv": {
		"DISPLAY": "host.docker.internal:0"
	},

	// Install GStreamer development libraries and X11 runtime deps.
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y git-lfs libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev gstreamer1.0-plugins-base gstreamer1.0-plugins-good gstreamer1.0-plugins-ugly gstreamer1.0-libav libxkbcommon-dev x11-apps libxkbcommon-x11-0 libxkbcommon-x11-dev python3-onnx",

	"mounts": [
    "source=${localWorkspaceFolderBasename}-target,target=${containerWorkspaceFolder}/target,type=volume"
	]
}
